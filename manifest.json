{
  "manifest_version": 3,
  "name": "Slop Evader",
  "version": "2.0",
  "description": "An extension for avoiding AI slop",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Slop Evader"
  },

  "icons": {
    "16": "logo-16.png",
    "48": "logo-48.png",
    "128": "logo-128.png"
  },

  "permissions": ["tabs", "storage"],

  "background": {
    "service_worker": "background.js"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tega.brain@gmail.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "gecko_android": {
        "strict_min_version": "113.0"
      }
    }
  }
}